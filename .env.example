PORT=3001

# SendGrid — create API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Must be a verified sender in SendGrid (Single Sender or domain authentication)
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Where form submissions are delivered
CONTACT_TO_EMAIL=info@masteralex.com

# Comma-separated frontend URLs (production + local dev)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://masteralex.com,https://www.masteralex.com,https://landing.masteralex.com
