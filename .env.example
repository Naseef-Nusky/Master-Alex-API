PORT=3001

# SendGrid API key — https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_key_here

# Verified sender in SendGrid (Single Sender or domain authentication)
# Best practice: use noreply@ after domain auth; only info@ works if that is your only verified sender
SENDGRID_FROM_EMAIL=info@masteralex.co.uk
SENDGRID_FROM_NAME=Master Alex

# Where form submissions are delivered (comma-separated for multiple inboxes)
CONTACT_TO_EMAIL=info@masteralex.co.uk

# Optional backup inbox (e.g. your Gmail) — receives a copy of every form submission
# CONTACT_BCC_EMAIL=you@gmail.com

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://masteralex.co.uk,https://www.masteralex.co.uk,https://services.masteralex.co.uk
